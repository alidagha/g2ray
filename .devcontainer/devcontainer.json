{
  "name": "swift-hub-a167cc",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "postStartCommand": "bash /usr/local/bin/start.sh & bash -c 'until gh codespace ports visibility 443:public -c $CODESPACE_NAME; do sleep 2; done'",
  "portsAttributes": {
    "443": {
      "label": "swift-hub-a167cc",
      "protocol": "http",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [
    443
  ],
  "hostRequirements": {
    "cpus": 2
  }
}
